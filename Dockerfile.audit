############################################
# Stage 1: Build
############################################
FROM rust:1.88-slim as builder

# Install build dependencies (required for OpenSSL / reqwest in the workspace)
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy workspace files
COPY Cargo.toml Cargo.lock ./
COPY market-service/ ./market-service/
COPY portfolio-service/ ./portfolio-service/
COPY audit-service/ ./audit-service/

# Build only the audit-service binary in release mode
RUN cargo build --release --bin audit-service

############################################
# Stage 2: Runtime
############################################
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/audit-service /usr/local/bin/audit-service

ENV HOST=0.0.0.0
ENV PORT=8083

EXPOSE 8083

CMD ["audit-service"]
