# ==============================================================================
# Mini Exchange Configuration (.env)
# ==============================================================================

# Common Configurations
RUST_LOG=info
HOST=0.0.0.0
BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=btcusdt@miniTicker/ethusdt@miniTicker/solusdt@miniTicker/adausdt@miniTicker/xrpusdt@miniTicker

# ------------------------------------------------------------------------------
# LOCAL CONFIGURATION (Default for running with 'cargo run' on host machine)
# ------------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MARKET_SERVICE_URL=http://localhost:8081
AUDIT_SERVICE_URL=http://localhost:8083

# Port bindings for individual services
MARKET_PORT=8081
PORTFOLIO_PORT=8082
AUDIT_PORT=8083

# ------------------------------------------------------------------------------
# DOCKER CONFIGURATION (Note: docker-compose overrides these automatically)
# ------------------------------------------------------------------------------
# KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# MARKET_SERVICE_URL=http://market-service:8081
# AUDIT_SERVICE_URL=http://audit-service:8083
